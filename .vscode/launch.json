{
    "configurations": [
        {
            "type": "java",
            "name": "NotificationServiceApplication",
            "request": "launch",
            "mainClass": "com.pfe.notification.NotificationServiceApplication",
            "projectName": "com.pfe-notification-service"
        },
        {
            "type": "java",
            "name": "DiscoveryApplication",
            "request": "launch",
            "mainClass": "com.example.discovery.DiscoveryApplication"
